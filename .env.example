# Common
HOST=127.0.0.1
NODE_ENV=development
PORT=8000
LOG_LEVEL=debug

# Database configuration
DB_HOST=127.0.0.1
DB_PORT=27017
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_AUTH_SOURCE=admin

# JWT configuration
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=12h

# Cors
CORS_ORIGIN=*

# Rate limit
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=500

# Database URL (constructed from variables above)
DATABASE_URL=mongodb://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?authSource=${DB_AUTH_SOURCE}&directConnection=true&connectTimeoutMS=3000