{
	"entryFile": "src/server.ts",
	"noImplicitAdditionalProperties": "throw",
	"controllerPathGlobs": ["src/api/rest/controllers/*.ts"],
	"spec": {
		"outputDirectory": "src/api/rest/docs",
		"specVersion": 3,
		"basePath": "/",
		"securityDefinitions": {
			"Bearer": {
				"type": "http",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		},
		"security": [
			{
				"Bearer": []
			}
		]
	},
	"routes": {
		"routesDir": "src/api/rest/routes",
		"middleware": "express",
		"authenticationModule": "src/api/rest/middlewares/auth.middleware.ts"
	}
}
