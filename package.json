{
	"name": "mvc-api-node-ts-rbac-express-graphql-mongo",
	"version": "1.3.0",
	"description": "RESTful API RBAC boilerplate with Node.js, Express, GraphQL, Socket.IO, TypeScript, TSOA, MongoDB and MVC pattern",
	"type": "commonjs",
	"main": "index.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"postinstall": "tsoa spec-and-routes",
		"predev": "tsoa spec-and-routes",
		"dev": "concurrently 'nodemon' 'nodemon -x tsoa spec-and-routes'",
		"prebuild": "tsoa spec-and-routes",
		"build": "tsc",
		"start": "node ./dist/server.js",
		"script": "ts-node --transpile-only ./scripts/index.ts",
		"format": "npx @biomejs/biome format --write",
		"lint": "npx @biomejs/biome lint --write",
		"check": "npx @biomejs/biome check --write",
		"check:unsafe": "npx @biomejs/biome check --write --unsafe",
		"clean": "rm -rf ./dist ./src/api/rest/routes/routes.ts ./src/api/rest/docs/swagger.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NorthSideBoy/mvc-rbac-api-node-express-ts-mongo.git"
	},
	"author": "Said Lucena <saidlucena519@gmail.com> (https://github.com/NorthSideBoy)",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/NorthSideBoy/mvc-rbac-api-node-express-ts-mongo/issues"
	},
	"homepage": "https://github.com/NorthSideBoy/mvc-rbac-api-node-express-ts-mongo#readme",
	"dependencies": {
		"@apollo/server": "^5.4.0",
		"@as-integrations/express5": "^1.1.2",
		"@socket.io/admin-ui": "^0.5.1",
		"@tsoa/runtime": "^7.0.0-alpha.0",
		"@typegoose/typegoose": "^13.2.1",
		"bcrypt": "^6.0.0",
		"body-parser": "^2.2.2",
		"class-transformer": "^0.5.1",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"express-rate-limit": "^8.2.1",
		"graphql-upload": "^17.0.0",
		"inquirer": "^13.2.5",
		"jsonwebtoken": "^9.0.3",
		"mime-types": "^3.0.2",
		"moment": "^2.30.1",
		"mongodb": "^7.1.0",
		"mongoose-autopopulate": "^1.2.1",
		"mongoose-paginate-v2": "^1.9.4",
		"multer": "^2.0.2",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"rate-limiter-flexible": "^9.1.1",
		"socket.io": "^4.8.3",
		"swagger-ui-express": "^5.0.1",
		"tsoa": "^7.0.0-alpha.0",
		"type-graphql": "^2.0.0-rc.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/bcrypt": "^6.0.0",
		"@types/body-parser": "^1.19.6",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/express-rate-limit": "^5.1.3",
		"@types/graphql-upload": "^17.0.0",
		"@types/inquirer": "^9.0.9",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^25.3.0",
		"@types/swagger-ui-dist": "^3.30.6",
		"@types/swagger-ui-express": "^4.1.8",
		"concurrently": "^9.2.1",
		"nodemon": "^3.1.11",
		"pino-pretty": "^11.3.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	}
}
